<!-- k4k:owner=user begin id=examples-accept -->
## Acceptance examples
1. argv=["echo","hi"] stdin="" -> stdout="hi\n" stderr="" exit=0
2. argv=["echo","a","b"] stdin="" -> stdout="a b\n" stderr="" exit=0
3. argv=["echo"] stdin="" -> stdout="\n" stderr="" exit=0
<!-- k4k:owner=user end -->

<!-- k4k:owner=user begin id=examples-refuse -->
## Refusing examples
1. (none in v0)
<!-- k4k:owner=user end -->

